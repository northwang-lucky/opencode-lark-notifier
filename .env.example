# 飞书应用凭证（必填）
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx

# 目标用户标识（三选一，优先邮箱）
LARK_USER_EMAIL=xxx@company.com
# LARK_USER_OPEN_ID=ou_xxx
# LARK_USER_ID=xxx

# 额外监听事件（逗号分隔，可选）
LARK_NOTIFIER_EVENTS=

# 速率限制（毫秒，0=不限制，默认30000）
LARK_NOTIFIER_RATE_LIMIT_MS=30000

# Idle冷却时间（毫秒，默认5000）
LARK_NOTIFIER_COOLDOWN_MS=5000

{
  "name": "opencode-lark-notifier",
  "version": "1.0.1",
  "description": "opencode plugin for lark notifications",
  "main": "./dist/index.js",
  "module": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "rimraf ./dist && bun build src/index.ts --outdir=dist",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,cjs}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "check": "bun run lint && prettier --check \"**/*.{ts,tsx,json,md,cjs}\"",
    "test": "bun test",
    "test:lark:real": "RUN_LARK_REAL_TESTS=1 bun test src/__tests__/lark-notifier-plugin.real.test.ts --timeout 30000",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.15.13",
    "@opencode-ai/sdk": "^1.15.13",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ]
}
